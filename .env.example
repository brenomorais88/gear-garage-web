# Public API (browser + server; must be reachable from Vercel serverless at request time)
NEXT_PUBLIC_GEARGARAGE_API_BASE_URL=http://localhost:8080

# Used for metadataBase / canonical URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Vercel: add the same keys in Project → Settings → Environment Variables.
# After creating or changing vars, trigger a new deployment (Redeploy) so the build and runtime see them.
# Prefer https:// for both values when the site and API are served over HTTPS.
